{
  "name": "diligenceos-agent-studio",
  "version": "1.0.0",
  "description": "Full-stack AI due diligence agent workspace with evidence retrieval, risk scoring, approval gates, audit traces, and evals.",
  "type": "module",
  "license": "MIT",
  "author": "lixian",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite --host 0.0.0.0",
    "test": "node --test test/*.test.js && npm run eval",
    "eval": "node eval/scenarios.test.js",
    "build": "vite build",
    "start": "node server/index.js",
    "health": "node scripts/project-health.js",
    "ops:check": "node scripts/ops-check.js",
    "ci:local": "npm run health && npm run ops:check && npm test && npm run build"
  },
  "keywords": [
    "ai-agent",
    "due-diligence",
    "risk-scoring",
    "tool-calling",
    "guardrails",
    "human-in-the-loop",
    "react",
    "express"
  ],
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
